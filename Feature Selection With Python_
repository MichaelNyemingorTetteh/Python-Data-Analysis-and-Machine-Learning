    "from sklearn.linear_model import LinearRegression\n",
    "from mlxtend.feature_selection import ExhaustiveFeatureSelector as EFS\n",
    "# Create the Linear Regression model\n",
    "model = LinearRegression()\n",
    "# Run Best Subset Selection using Exhaustive Feature Selection\n",
    "bestsubset = EFS(\n",
    "    estimator=model,\n",
    "    min_features=1,\n",
    "    max_features=11,\n",
    "    scoring='r2',\n",
    "    cv=5\n",
    ")\n",
    "\n",
    "# Fit the feature selector to the dataset\n",
    "bestsubset.fit(X, Y)\n"
